{
  "platform": "web",
  "stack": "react",
  "designSource": { "type": "storybook", "path": "web/.storybook", "mcp": "http://localhost:6006/mcp" },
  "knowledgePack": "web",
  "applyTo": ["web/**"],
  "build": "npm --prefix web run build",
  "test": "npm --prefix web run test",
  "backend": {
    "stack": "dotnet",
    "solution": "Tessera.slnx",
    "architectureDocs": ["docs/adr", "docs/architecture.md"],
    "applyTo": ["src/**", "tests/**"],
    "build": "dotnet build Tessera.slnx",
    "test": "dotnet test Tessera.slnx"
  },
  "iac": {
    "kind": "mixed",
    "path": "deploy",
    "plan": "kubectl diff -k deploy/k8s",
    "policy": "kubeconform -summary deploy/k8s",
    "applyTo": ["deploy/**"]
  },
  "ops": {
    "kind": "homelab-mcp",
    "mode": "read-only",
    "mcpServer": "homelab",
    "purpose": ["runtime-health", "logs", "deployment-verification", "version-drift"],
    "requiresApprovalFor": ["mutations", "reconcile", "restart", "secret-access", "network-change"]
  }
}
